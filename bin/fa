#!/bin/bash
# fa: Fuzzy file search - ALL files including hidden (dotfiles)

selected=$(fdfind --type f --hidden --strip-cwd-prefix \
  --exclude 'node_modules' \
  --exclude '__pycache__' \
  --exclude '*.pyc' \
  --exclude 'venv' \
  --exclude 'dist' \
  --exclude 'build' \
  --exclude 'target' \
  --exclude '*.log' | \
  fzf --preview="bat --color=always --line-range :500 {}" \
      --height=60% \
      --border \
      --prompt="All Files: " \
      --bind="j:down,k:up,ctrl-j:down,ctrl-k:up" \
      --bind="enter:execute-silent(nvim {})+abort" \
      --bind="esc:abort")

if [ -n "$selected" ]; then
  nvim "$selected"
fi