#!/bin/bash
# fa: Fuzzy file search - ALL files including hidden (dotfiles)
# Telescope-style (type immediately)

if [ -n "$TMUX" ]; then
  selected=$(fdfind --type f --hidden . --strip-cwd-prefix \
    --exclude 'node_modules' \
    --exclude '__pycache__' \
    --exclude '*.pyc' \
    --exclude 'venv' \
    --exclude 'dist' \
    --exclude 'build' \
    --exclude 'target' \
    --exclude '*.log' | \
    fzf-tmux -p60% \
      --layout=reverse-list \
      --with-nth=1 \
      --preview="bat --color=always --line-range :500 {}" \
      --prompt="🔍 " \
      --header="j/k: navigate | enter: open | esc: cancel" \
      --bind="j:down,k:up,ctrl-j:down,ctrl-k:up,enter:accept,esc:abort")
else
  selected=$(fdfind --type f --hidden . --strip-cwd-prefix \
    --exclude 'node_modules' \
    --exclude '__pycache__' \
    --exclude '*.pyc' \
    --exclude 'venv' \
    --exclude 'dist' \
    --exclude 'build' \
    --exclude 'target' \
    --exclude '*.log' | \
    fzf --layout=reverse-list \
      --with-nth=1 \
      --preview="bat --color=always --line-range :500 {}" \
      --height=60% \
      --border \
      --prompt="🔍 " \
      --header="j/k: navigate | enter: open | esc: cancel" \
      --bind="j:down,k:up,ctrl-j:down,ctrl-k:up,enter:accept,esc:abort")
fi

if [ -n "$selected" ]; then
  nvim "$selected"
fi