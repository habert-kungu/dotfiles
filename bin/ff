#!/bin/bash
# ff: Fuzzy file search - Telescope-style (type immediately)

if [ -n "$TMUX" ]; then
  selected=$(fdfind --type f . --strip-cwd-prefix \
    --exclude '.git' \
    --exclude 'node_modules' \
    --exclude '__pycache__' \
    --exclude '*.pyc' \
    --exclude '.venv' \
    --exclude 'venv' \
    --exclude 'dist' \
    --exclude 'build' \
    --exclude 'target' \
    --exclude '.cache' \
    --exclude 'anaconda3' \
    --exclude 'miniconda3' \
    --exclude '.cargo' \
    --exclude 'vendor' \
    --exclude '.next' \
    --exclude '.nuxt' \
    --exclude '*.log' \
    --exclude '.*' | \
    fzf-tmux -p60% \
      --layout=reverse-list \
      --with-nth=1 \
      --preview="bat --color=always --line-range :500 {}" \
      --prompt="🔍 " \
      --header="j/k: navigate | enter: open | esc: cancel" \
      --bind="j:down,k:up,ctrl-j:down,ctrl-k:up,enter:accept,esc:abort,gg:top,G:bottom")
else
  selected=$(fdfind --type f . --strip-cwd-prefix \
    --exclude '.git' \
    --exclude 'node_modules' \
    --exclude '__pycache__' \
    --exclude '*.pyc' \
    --exclude '.venv' \
    --exclude 'venv' \
    --exclude 'dist' \
    --exclude 'build' \
    --exclude 'target' \
    --exclude '.cache' \
    --exclude 'anaconda3' \
    --exclude 'miniconda3' \
    --exclude '.cargo' \
    --exclude 'vendor' \
    --exclude '.next' \
    --exclude '.nuxt' \
    --exclude '*.log' \
    --exclude '.*' | \
    fzf --layout=reverse-list \
      --with-nth=1 \
      --preview="bat --color=always --line-range :500 {}" \
      --height=60% \
      --border \
      --prompt="🔍 " \
      --header="j/k: navigate | enter: open | esc: cancel" \
      --bind="j:down,k:up,ctrl-j:down,ctrl-k:up,enter:accept,esc:abort,gg:top,G:bottom")
fi

if [ -n "$selected" ]; then
  nvim "$selected"
fi