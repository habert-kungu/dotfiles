#!/bin/bash
# ff: Fuzzy file search - search by NAME, open in nvim

if [ -n "$TMUX" ]; then
  selected=$(fdfind --type f . ~ --strip-cwd-prefix \
    --exclude '.git' \
    --exclude 'node_modules' \
    --exclude '__pycache__' \
    --exclude '*.pyc' \
    --exclude '.venv' \
    --exclude 'venv' \
    --exclude 'dist' \
    --exclude 'build' \
    --exclude 'target' \
    --exclude '.cache' \
    --exclude 'anaconda3' \
    --exclude 'miniconda3' \
    --exclude '.cargo' \
    --exclude 'vendor' \
    --exclude '.next' \
    --exclude '.nuxt' \
    --exclude '*.log' \
    --exclude '.*' | \
    fzf-tmux -p60% \
      --with-nth=1 \
      --preview="bat --color=always --line-range :500 {}" \
      --prompt="File: " \
      --bind="j:down,k:up,ctrl-j:down,ctrl-k:up" \
      --header="Type to search by filename")
else
  selected=$(fdfind --type f . ~ --strip-cwd-prefix \
    --exclude '.git' \
    --exclude 'node_modules' \
    --exclude '__pycache__' \
    --exclude '*.pyc' \
    --exclude '.venv' \
    --exclude 'venv' \
    --exclude 'dist' \
    --exclude 'build' \
    --exclude 'target' \
    --exclude '.cache' \
    --exclude 'anaconda3' \
    --exclude 'miniconda3' \
    --exclude '.cargo' \
    --exclude 'vendor' \
    --exclude '.next' \
    --exclude '.nuxt' \
    --exclude '*.log' \
    --exclude '.*' | \
    fzf --with-nth=1 \
      --preview="bat --color=always --line-range :500 {}" \
      --height=60% \
      --border \
      --prompt="File: " \
      --bind="j:down,k:up,ctrl-j:down,ctrl-k:up" \
      --header="Type to search by filename")
fi

if [ -n "$selected" ]; then
  nvim "$selected"
fi