#!/bin/bash
# fd: Fuzzy directory search - Telescope-style (type immediately)

if [ -n "$TMUX" ]; then
  selected=$(fdfind --type d . --strip-cwd-prefix \
    --max-depth 3 \
    --exclude '.git' \
    --exclude 'node_modules' \
    --exclude '__pycache__' \
    --exclude '.venv' \
    --exclude 'venv' \
    --exclude 'dist' \
    --exclude 'build' \
    --exclude 'target' \
    --exclude '.cache' \
    --exclude 'anaconda3' \
    --exclude 'miniconda3' \
    --exclude '.cargo' \
    --exclude 'vendor' \
    --exclude '.next' \
    --exclude '.nuxt' \
    --exclude '.*' | \
    fzf-tmux -p60% \
      --layout=reverse-list \
      --with-nth=1 \
      --preview="eza --icons=always --tree -L 2 {} 2>/dev/null" \
      --prompt="📁 " \
      --header="j/k: navigate | enter: open | esc: cancel" \
      --bind="j:down,k:up,ctrl-j:down,ctrl-k:up,enter:accept,esc:abort,gg:top,G:bottom")
else
  selected=$(fdfind --type d . --strip-cwd-prefix \
    --max-depth 3 \
    --exclude '.git' \
    --exclude 'node_modules' \
    --exclude '__pycache__' \
    --exclude '.venv' \
    --exclude 'venv' \
    --exclude 'dist' \
    --exclude 'build' \
    --exclude 'target' \
    --exclude '.cache' \
    --exclude 'anaconda3' \
    --exclude 'miniconda3' \
    --exclude '.cargo' \
    --exclude 'vendor' \
    --exclude '.next' \
    --exclude '.nuxt' \
    --exclude '.*' | \
    fzf --layout=reverse-list \
      --with-nth=1 \
      --preview="eza --icons=always --tree -L 2 {} 2>/dev/null" \
      --height=60% \
      --border \
      --prompt="📁 " \
      --header="j/k: navigate | enter: open | esc: cancel" \
      --bind="j:down,k:up,ctrl-j:down,ctrl-k:up,enter:accept,esc:abort,gg:top,G:bottom")
fi

if [ -n "$selected" ]; then
  cd "$selected" && nvim .
fi