#!/bin/bash
# fd: Fuzzy directory search - search by NAME, cd into dir, open nvim
# Shows just directory names, not full paths

dirs=$(fdfind --type d . --strip-cwd-prefix \
  --exclude '.git' \
  --exclude 'node_modules' \
  --exclude '__pycache__' \
  --exclude '.venv' \
  --exclude 'venv' \
  --exclude 'dist' \
  --exclude 'build' \
  --exclude 'target' \
  --exclude '.cache' \
  --exclude 'anaconda3' \
  --exclude 'miniconda3' \
  --exclude '.cargo' \
  --exclude 'vendor' \
  --exclude '.next' \
  --exclude '.nuxt' \
  --exclude '.*' | \
  xargs -I{} basename {} | sort -u)

if [ -n "$TMUX" ]; then
  selected=$(echo "$dirs" | \
    fzf-tmux -p60% \
      --preview="eza --icons=always --tree -L 2 2>/dev/null" \
      --prompt="Dir: " \
      --bind="j:down,k:up,ctrl-j:down,ctrl-k:up" \
      --header="Type to search by name")
else
  selected=$(echo "$dirs" | \
    fzf --preview="eza --icons=always --tree -L 2 2>/dev/null" \
      --height=60% \
      --border \
      --prompt="Dir: " \
      --bind="j:down,k:up,ctrl-j:down,ctrl-k:up" \
      --header="Type to search by name")
fi

if [ -n "$selected" ]; then
  actual_dir=$(fdfind --type d . --strip-cwd-prefix \
    --exclude '.git' \
    --exclude 'node_modules' \
    --exclude '__pycache__' \
    --exclude '.venv' \
    --exclude 'venv' \
    --exclude 'dist' \
    --exclude 'build' \
    --exclude 'target' \
    --exclude '.cache' \
    --exclude 'anaconda3' \
    --exclude 'miniconda3' \
    --exclude '.cargo' \
    --exclude 'vendor' \
    --exclude '.next' \
    --exclude '.nuxt' \
    --exclude '.*' | \
    grep "/$selected$" | head -1)
  
  if [ -n "$actual_dir" ] && [ -d "$actual_dir" ]; then
    cd "$actual_dir" && nvim .
  else
    echo "Directory not found: $selected"
  fi
fi