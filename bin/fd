#!/bin/bash
# fd: Fuzzy directory search - cd into selected dir then open nvim
# Search by directory name only

if [ -n "$TMUX" ]; then
  selected=$(fdfind --type d . --strip-cwd-prefix \
    --max-depth 3 \
    --exclude '.git' \
    --exclude 'node_modules' \
    --exclude '__pycache__' \
    --exclude '.venv' \
    --exclude 'venv' \
    --exclude 'dist' \
    --exclude 'build' \
    --exclude 'target' \
    --exclude '.cache' \
    --exclude 'anaconda3' \
    --exclude 'miniconda3' \
    --exclude '.cargo' \
    --exclude 'vendor' \
    --exclude '.next' \
    --exclude '.nuxt' \
    --exclude '.*' | \
    fzf-tmux -p60% \
      --with-nth=1 \
      --preview="eza --icons=always --tree -L 2 {} 2>/dev/null" \
      --prompt="Dir: " \
      --bind="j:down,k:up,ctrl-j:down,ctrl-k:up" \
      --header="Type to search by directory name")
else
  selected=$(fdfind --type d . --strip-cwd-prefix \
    --max-depth 3 \
    --exclude '.git' \
    --exclude 'node_modules' \
    --exclude '__pycache__' \
    --exclude '.venv' \
    --exclude 'venv' \
    --exclude 'dist' \
    --exclude 'build' \
    --exclude 'target' \
    --exclude '.cache' \
    --exclude 'anaconda3' \
    --exclude 'miniconda3' \
    --exclude '.cargo' \
    --exclude 'vendor' \
    --exclude '.next' \
    --exclude '.nuxt' \
    --exclude '.*' | \
    fzf --with-nth=1 \
      --preview="eza --icons=always --tree -L 2 {} 2>/dev/null" \
      --height=60% \
      --border \
      --prompt="Dir: " \
      --bind="j:down,k:up,ctrl-j:down,ctrl-k:up" \
      --header="Type to search by directory name")
fi

if [ -n "$selected" ]; then
  cd "$selected" && nvim .
fi