#!/bin/bash
# Quick launcher - shows all available commands
# Like Omarchy's SUPER+P menu

options=(
  "ff: Fuzzy file search (no hidden) → nvim"
  "fa: Fuzzy search ALL files (including hidden)"
  "fp: Fuzzy search → preview only"
  "fcpp: Fuzzy find C++ → compile & run"
  "makec <file>: Compile C file"
  "makecpp <file>: Compile C++ file"
  "lzd: Open lazydocker"
  "nvim: Open neovim"
  "lazygit: Git TUI"
)

if [ -n "$TMUX" ]; then
  choice=$(printf '%s\n' "${options[@]}" | \
    fzf-tmux -p50% \
      --bind="j:down,k:up,ctrl-j:down,ctrl-k:up" \
      --prompt="Run: " \
      --header="Quick Commands (j/k to navigate)" \
      --header-first)
else
  choice=$(printf '%s\n' "${options[@]}" | \
    fzf --height=50% \
      --border \
      --bind="j:down,k:up,ctrl-j:down,ctrl-k:up" \
      --prompt="Run: " \
      --header="Quick Commands (j/k to navigate, enter to run)" \
      --header-first)
fi

if [ -z "$choice" ]; then
  exit 0
fi

# Extract the command from the choice
cmd=$(echo "$choice" | cut -d: -f1)

# Run the command
case "$cmd" in
  ff|fa|fp)
    ~/bin/"$cmd"
    ;;
  fcpp)
    fcpp
    ;;
  makec|makecpp)
    echo "Usage: $cmd <filename>"
    ;;
  lzd)
    lazydocker
    ;;
  nvim)
    nvim
    ;;
  lazygit)
    lazygit
    ;;
  *)
    echo "Unknown command: $cmd"
    ;;
esac