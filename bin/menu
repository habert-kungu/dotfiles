#!/bin/bash
# Quick launcher - Telescope-style (type immediately)

options=(
  "ff: Fuzzy file search (no hidden) → nvim"
  "fa: Fuzzy search ALL files (including hidden)"
  "fd: Fuzzy directory search → cd into dir"
  "fp: Fuzzy search → preview only"
  "fcpp: Fuzzy find C++ → compile & run"
  "wifi: Connect to WiFi network"
  "bt: Connect to Bluetooth device"
  "makec <file>: Compile C file"
  "makecpp <file>: Compile C++ file"
  "lzd: Open lazydocker"
  "nvim: Open neovim"
  "lazygit: Git TUI"
  "menu: Show this menu"
)

if [ -n "$TMUX" ]; then
  choice=$(printf '%s\n' "${options[@]}" | \
    fzf-tmux -p50% \
      --layout=reverse-list \
      --prompt="⚡ " \
      --header="j/k: navigate | enter: run | esc: cancel" \
      --bind="j:down,k:up,ctrl-j:down,ctrl-k:up,enter:accept,esc:abort")
else
  choice=$(printf '%s\n' "${options[@]}" | \
    fzf --height=50% \
      --border \
      --layout=reverse-list \
      --prompt="⚡ " \
      --header="j/k: navigate | enter: run | esc: cancel" \
      --bind="j:down,k:up,ctrl-j:down,ctrl-k:up,enter:accept,esc:abort")
fi

if [ -z "$choice" ]; then
  exit 0
fi

cmd=$(echo "$choice" | cut -d: -f1)

case "$cmd" in
  ff|fa|fp|fd)
    ~/bin/"$cmd"
    ;;
  wifi)
    ~/bin/wifi-connect
    ;;
  bt)
    ~/bin/bluetooth-connect
    ;;
  fcpp)
    fcpp
    ;;
  makec|makecpp)
    echo "Usage: $cmd <filename>"
    ;;
  lzd)
    lazydocker
    ;;
  nvim)
    nvim
    ;;
  lazygit)
    lazygit
    ;;
  menu)
    ~/bin/menu
    ;;
  *)
    echo "Unknown command: $cmd"
    ;;
esac