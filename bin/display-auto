#!/bin/bash
# Auto display manager for i3
# Automatically switches between laptop and external monitor

# Get connected displays
connected=$(xrandr --query | grep " connected" | awk '{print $1}')

echo "Connected displays: $connected"

# Primary external monitor (adjust to your actual output name)
external=""
for display in DP-1-3 DP-1-1 DP-1 HDMI-1; do
    if echo "$connected" | grep -q "$display"; then
        external=$display
        break
    fi
done

# Laptop display
laptop="eDP-1"

# Check what's connected and set displays
if [ -n "$external" ]; then
    # External monitor connected - use it
    echo "Using external monitor: $external"
    xrandr --output "$external" --mode 1920x1080 --pos 0x0
    xrandr --output "$laptop" --off
else
    # No external - use laptop display
    echo "Using laptop display: $laptop"
    xrandr --output "$laptop" --mode 1920x1080 --pos 0x0
    
    # Turn off any external monitors
    for display in DP-1-3 DP-1-1 DP-1 HDMI-1; do
        xrandr --output "$display" --off 2>/dev/null
    done
fi

# Optional: Set wallpaper after display change
sleep 1
feh --bg-fill ~/Pictures/wallpaper.jpg