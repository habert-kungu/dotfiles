###############################################################################
# Custom keybindings overlay for Regolith
# Overrides Regolith defaults for j/k/l/; navigation, rofi launcher, wezterm, etc.
###############################################################################

set $mod Mod4

# ─── Window borders ───
for_window [all] border pixel 0
for_window [class="^.*"] border pixel 0

# ─── Gaps ───
gaps inner 2
gaps outer 2
# Disable smart gaps (we want gaps always)
smart_gaps off

# ─── Autostart ───
exec --no-startup-id dex --autostart --environment i3
exec --no-startup-id export GTK_THEME=Adwaita:dark
exec_always --no-startup-id sh $HOME/.config/polybar/launch.sh
exec_always --no-startup-id sh -c '~/.fehbg 2>/dev/null || feh --bg-fill ~/Pictures/wallpapers/bento.png'
exec_always picom --config ~/.config/picom/picom.conf

# ─── Application shortcuts (overrides Regolith terminal/launcher) ───
bindsym $mod+Return exec wezterm
bindsym $mod+b exec firefox
bindsym $mod+t exec thunar
bindsym $mod+c exec code
bindsym $mod+d exec rofi -show drun

# ─── Navigation (j=left, k=down, l=up, ;=right) ───
bindsym $mod+j focus left
bindsym $mod+k focus down
bindsym $mod+l focus up
bindsym $mod+semicolon focus right
bindsym $mod+Shift+j move left
bindsym $mod+Shift+k move down
bindsym $mod+Shift+l move up
bindsym $mod+Shift+semicolon move right

# ─── Layout overrides ───
bindsym $mod+h split h
bindsym $mod+e layout toggle split
bindsym $mod+n layout default
bindsym $mod+Shift+space floating toggle
bindsym $mod+space focus mode_toggle
bindsym $mod+a focus parent

# ─── Kill window (Regolith uses Shift+q, we want just q) ───
bindsym $mod+q kill

# ─── System overrides ───
bindsym $mod+Shift+e exec "i3-nagbar -t warning -m 'You pressed the exit shortcut. Do you really want to exit i3? This will end your X session.' -B 'Yes, exit i3' 'i3-msg exit'"
bindsym $mod+Shift+x exec gnome-session-quit --logout
bindsym $mod+Shift+p exec gnome-session-quit --power-off
bindsym $mod+Shift+Ctrl+p exec gnome-session-quit --reboot

# ─── Resize mode ───
bindsym $mod+r mode "resize"
mode "resize" {
    bindsym j resize shrink width 10 px or 10 ppt
    bindsym k resize grow height 10 px or 10 ppt
    bindsym l resize shrink height 10 px or 10 ppt
    bindsym semicolon resize grow width 10 px or 10 ppt
    bindsym Left resize shrink width 10 px or 10 ppt
    bindsym Down resize grow height 10 px or 10 ppt
    bindsym Up resize shrink height 10 px or 10 ppt
    bindsym Right resize grow width 10 px or 10 ppt
    bindsym Return mode "default"
    bindsym Escape mode "default"
    bindsym $mod+r mode "default"
}

# ─── Extra ───
bindsym Print exec maim ~/Pictures/screenshot_$(date +%Y-%m-%d_%H-%M-%S).png
bindsym $mod+Print exec maim -s ~/Pictures/screenshot_$(date +%Y-%m-%d_%H-%M-%S).png
bindsym $mod+Shift+d exec gnome-control-center display
bindsym $mod+Shift+w exec --no-startup-id ~/.local/bin/random-wallpaper.sh

# ─── Audio ───
bindsym F1 exec --no-startup-id wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
bindsym F2 exec --no-startup-id wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
bindsym F3 exec --no-startup-id wpctl set-volume -l 1.5 @DEFAULT_AUDIO_SINK@ 5%+
bindsym XF86AudioMute        exec --no-startup-id wpctl set-mute   @DEFAULT_AUDIO_SINK@ toggle
bindsym XF86AudioLowerVolume exec --no-startup-id wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
bindsym XF86AudioRaiseVolume exec --no-startup-id wpctl set-volume -l 1.5 @DEFAULT_AUDIO_SINK@ 5%+

# ─── Color scheme ───
client.focused          #b8bb26 #282828  #ebdbb2  #b8bb26   #282828
client.focused_inactive #b8bb26 #282828  #a89984  #b8bb26   #282828
client.unfocused        #b8bb26 #282828  #928374  #b8bb26   #282828
client.urgent           #b8bb26 #282828  #fb4934  #b8bb26   #282828
client.placeholder      #b8bb26 #282828  #a89984  #b8bb26   #282828
client.background       #030C11
