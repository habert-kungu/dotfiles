###############################################################################
# Custom i3 config for Regolith
# Provides custom keybindings while preserving GNOME session integration.
# Placed at ~/.config/regolith3/i3/config — Regolith uses this instead of
# the system /etc/regolith/i3/config if this file exists.
###############################################################################

set $mod Mod4

# ─── Bar ───
bar {
  position top
  height 30

  font pango:JetBrainsMono Nerd Font 12, Symbols Nerd Font 14

  colors {
    background #1c1c1c
    statusline #cdd6f4
    separator  #585b70

#                       border  background text
    focused_workspace   #89b4fa #1c1c1c    #cdd6f4
    active_workspace    #89b4fa #1c1c1c    #cdd6f4
    inactive_workspace  #585b70 #1c1c1c    #585b70
    urgent_workspace    #f38ba8 #1c1c1c    #f38ba8
  }

  status_command i3xrocks -u ~/.config/regolith3/i3xrocks/conf.d -d /usr/share/i3xrocks/conf.d
  tray_output primary
  strip_workspace_numbers yes
  workspace_min_width 30
}

# ─── Window borders ───
for_window [all] border pixel 0
for_window [class="^.*"] border pixel 0
default_floating_border pixel 1
floating_maximum_size -1 x -1
hide_edge_borders smart
focus_follows_mouse no

# ─── Gaps ───
gaps inner 6
gaps outer 3
smart_gaps on
popup_during_fullscreen smart

# ─── DBus activation (GNOME session integration) ───
exec --no-startup-id systemctl --user import-environment XDG_CURRENT_DESKTOP DISPLAY I3SOCK
exec --no-startup-id hash dbus-update-activation-environment 2>/dev/null && \
     dbus-update-activation-environment --systemd XDG_CURRENT_DESKTOP DISPLAY I3SOCK

# ─── GNOME session services ───
exec --no-startup-id /usr/libexec/gnome-flashback-media-keys
exec --no-startup-id /usr/bin/nm-applet
exec --no-startup-id /usr/bin/rofication-daemon
exec --no-startup-id /usr/bin/unclutter -b
exec --no-startup-id i3-swap-focus

# ─── Autostart ───
exec --no-startup-id dex --autostart --environment i3
exec --no-startup-id export GTK_THEME=Adwaita:dark
exec_always --no-startup-id sh -c '~/.fehbg 2>/dev/null || feh --bg-fill ~/Pictures/wallpapers/bento.png'
exec_always picom --config ~/.config/picom/picom.conf

# ─── Navigation (j=left, k=down, l=up, ;=right) ───
bindsym $mod+j focus left
bindsym $mod+k focus down
bindsym $mod+l focus up
bindsym $mod+semicolon focus right
bindsym $mod+Shift+j move left
bindsym $mod+Shift+k move down
bindsym $mod+Shift+l move up
bindsym $mod+Shift+semicolon move right

# ─── Arrow key navigation (fallback) ───
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

# ─── Application shortcuts ───
bindsym $mod+Return exec wezterm
bindsym $mod+d exec rofi -show drun
bindsym $mod+b exec firefox
bindsym $mod+c exec code
bindsym $mod+t exec thunar

# ─── Layout ───
bindsym $mod+Shift+h split h
bindsym $mod+v split v
bindsym $mod+f fullscreen toggle
bindsym $mod+e layout toggle split
bindsym $mod+n layout default
bindsym $mod+Shift+space floating toggle
bindsym $mod+space focus mode_toggle
bindsym $mod+a focus parent

# ─── Kill window ───
bindsym $mod+q kill

# ─── Workspaces ───
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"

bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws10

bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9
bindsym $mod+Shift+0 move container to workspace number $ws10

# ─── System ───
bindsym $mod+Shift+c reload
bindsym $mod+Ctrl+r restart
bindsym $mod+Escape exec dbus-send --type=method_call --dest=org.gnome.ScreenSaver /org/gnome/ScreenSaver org.gnome.ScreenSaver.Lock
bindsym $mod+Shift+e exec "i3-nagbar -t warning -m 'Exit i3? This ends your X session.' -B 'Yes, exit i3' 'i3-msg exit'"
bindsym $mod+Shift+x exec gnome-session-quit --logout
bindsym $mod+Shift+p exec gnome-session-quit --power-off
bindsym $mod+Shift+Ctrl+p exec gnome-session-quit --reboot

# ─── Resize mode ───
mode "resize" {
    bindsym j resize shrink width 10 px or 10 ppt
    bindsym k resize grow height 10 px or 10 ppt
    bindsym l resize shrink height 10 px or 10 ppt
    bindsym semicolon resize grow width 10 px or 10 ppt
    bindsym Left resize shrink width 10 px or 10 ppt
    bindsym Down resize grow height 10 px or 10 ppt
    bindsym Up resize shrink height 10 px or 10 ppt
    bindsym Right resize grow width 10 px or 10 ppt
    bindsym Return mode "default"
    bindsym Escape mode "default"
    bindsym $mod+r mode "default"
}
bindsym $mod+r mode "resize"

# ─── Extras ───
bindsym $mod+Shift+d exec gnome-control-center display
bindsym $mod+Shift+w exec --no-startup-id ~/.local/bin/random-wallpaper.sh
bindsym Print exec maim ~/Pictures/screenshot_$(date +%Y-%m-%d_%H-%M-%S).png
bindsym $mod+Print exec maim -s ~/Pictures/screenshot_$(date +%Y-%m-%d_%H-%M-%S).png

# ─── Audio ───
bindsym F1 exec --no-startup-id wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
bindsym F2 exec --no-startup-id wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
bindsym F3 exec --no-startup-id wpctl set-volume -l 1.5 @DEFAULT_AUDIO_SINK@ 5%+
bindsym XF86AudioMute        exec --no-startup-id wpctl set-mute   @DEFAULT_AUDIO_SINK@ toggle
bindsym XF86AudioLowerVolume exec --no-startup-id wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
bindsym XF86AudioRaiseVolume exec --no-startup-id wpctl set-volume -l 1.5 @DEFAULT_AUDIO_SINK@ 5%+

# ─── Colors ───
client.focused          #b8bb26 #282828  #ebdbb2  #b8bb26   #282828
client.focused_inactive #b8bb26 #282828  #a89984  #b8bb26   #282828
client.unfocused        #b8bb26 #282828  #928374  #b8bb26   #282828
client.urgent           #b8bb26 #282828  #fb4934  #b8bb26   #282828
client.placeholder      #b8bb26 #282828  #a89984  #b8bb26   #282828
client.background       #030C11

# ─── Floating modifier ───
floating_modifier $mod
tiling_drag modifier titlebar

# ─── Notify systemd about successful session start ───
exec --no-startup-id [ -z "${NOTIFY_SOCKET-}" ] \
  && systemctl --user start regolith-x11.target \
  || systemd-notify --ready
